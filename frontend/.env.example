# Public base path for production builds.
# Set to '/moka/' when serving under a subpath (e.g. alvarosod.dev/moka).
# Leave unset or '/' for root deployments.
VITE_BASE=/moka/

# Backend API base URL.
# Leave unset when frontend and backend share the same domain (Caddy proxy).
# Only needed when deploying frontend and backend on separate origins.
# VITE_API_URL=https://api.yourdomain.com/api
